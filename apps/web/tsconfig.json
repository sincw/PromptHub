{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "jsx": "react-jsx",
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@prompthub/shared": ["../../packages/shared/types/index.ts"],
      "@prompthub/shared/*": ["../../packages/shared/*/index.ts"],
      "@prompthub/db": ["../../packages/db/src/index.ts"],
      "@prompthub/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
